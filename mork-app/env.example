# NOTE:
# - The app reads from mork-app/.env.local at runtime.
# - env.example is only a template used to create .env.local once.
# - If .env.local already exists, edit .env.local directly.
DATABASE_URL="file:./dev.db"
MORK_WALLET=""
MORK_WALLET_SECRET_KEY=""
SOLANA_RPC="https://api.mainnet-beta.solana.com"
OLLAMA_HOST="http://127.0.0.1:11434"
OLLAMA_MODEL="llama3.2:3b"
OLLAMA_CTX="4096"
OLLAMA_TIMEOUT_MS="90000"
# sol-mev-bot log verbosity: debug | info | warn | error
LOG_LEVEL="info"
# Optional reachability probe timeout used by preflight host detection.
OLLAMA_REACHABILITY_TIMEOUT_MS="4000"
MORK_SETUP_WALLET_MODE="auto"

# Direct in-app Jupiter swap (server-side signing)
# 0 = disabled (safe default), 1 = enabled (allows live swap route when other safety gates pass)
MORK_AGENT_SWAP_ENABLED="0"
MORK_AGENT_SWAP_MAX_SOL="0.25"
JUP_BASE_URL="https://api.jup.ag"
# Optional comma-separated fallback endpoints (tried in order, then JUP_BASE_URL, then built-ins).
# Recommended free setup: "https://api.jup.ag,https://lite-api.jup.ag"
JUP_BASE_URLS="https://api.jup.ag,https://lite-api.jup.ag"
# Optional Jupiter REST timeout used by token search + quote metadata lookups.
JUP_TIMEOUT_MS="10000"
SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
# Optional comma-separated RPC pool for arb failover/rotation on 429.
# Example:
# SOLANA_RPC_URLS="https://rpc-1.example.com,https://rpc-2.example.com,https://api.mainnet-beta.solana.com"
SOLANA_RPC_URLS=""
# Legacy fallback alias used by some services/routes.
RPC_URL="https://api.mainnet-beta.solana.com"
# Telegram chat command routing
TELEGRAM_CHAT_ID=""
VOICE_REPLY_PROBABILITY="0.2"
# Sherpa meme compose timeout tuning (helps avoid fallback captions when Core/Ollama is slow).
MEME_CORE_REFLECT_TIMEOUT_SECONDS="20"
MEME_CORE_COMPOSE_TIMEOUT_SECONDS="12"
# OpenAI fallback for Sherpa (0=off, 1=on; requires Sherpa OpenAI key configured in Sherpa UI).
USE_OPENAI="0"
# Optional arb scan throttle (lower = fewer RPC bursts, slower scans)
SCAN_BATCH_SIZE="2"

# Media generation (chat image/video)
# Image defaults to Pollinations free endpoint (no API key required).
MEDIA_IMAGE_MODEL="flux"
MEDIA_IMAGE_WIDTH="1024"
MEDIA_IMAGE_HEIGHT="1024"
# Optional video endpoint for free-tier providers you control.
# Leave empty to use Pollinations video by default (https://gen.pollinations.ai/video/{prompt}).
# Set this only if you want a custom endpoint that returns binary video bytes from JSON { prompt }.
MEDIA_VIDEO_ENDPOINT=""
MEDIA_VIDEO_METHOD="POST"
# Optional Pollinations model override (when MEDIA_VIDEO_ENDPOINT is empty).
MEDIA_VIDEO_MODEL=""
# Optional deterministic seed for Pollinations video (integer).
MEDIA_VIDEO_SEED=""
# Optional auth token:
# - Pollinations key for default provider (Bearer token), or
# - your custom provider token when MEDIA_VIDEO_ENDPOINT is set.
MEDIA_VIDEO_TOKEN=""
