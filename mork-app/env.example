# NOTE:
# - The app reads from mork-app/.env.local at runtime.
# - env.example is only a template used to create .env.local once.
# - If .env.local already exists, edit .env.local directly.
DATABASE_URL="file:./dev.db"
MORK_WALLET=""
MORK_WALLET_SECRET_KEY=""
SOLANA_RPC="https://api.mainnet-beta.solana.com"
OLLAMA_HOST="http://127.0.0.1:11434"
OLLAMA_MODEL="llama3.2:3b"
OLLAMA_CTX="4096"
OLLAMA_TIMEOUT_MS="90000"

LOG_LEVEL="info"

OLLAMA_REACHABILITY_TIMEOUT_MS="4000"
MORK_SETUP_WALLET_MODE="auto"

# 0 = disabled (safe default), 1 = enabled (allows live swap route when other safety gates pass)
MORK_AGENT_SWAP_ENABLED="0"
MORK_AGENT_SWAP_MAX_SOL="0.25"
JUP_BASE_URL="https://api.jup.ag"

JUP_BASE_URLS="https://api.jup.ag,https://lite-api.jup.ag"

JUP_TIMEOUT_MS="10000"
SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"


SOLANA_RPC_URLS=""
# Legacy fallback alias used by some services/routes.
RPC_URL="https://api.mainnet-beta.solana.com"

TELEGRAM_CHAT_ID=""
VOICE_REPLY_PROBABILITY="0.2"

MEME_CORE_REFLECT_TIMEOUT_SECONDS="20"
MEME_CORE_COMPOSE_TIMEOUT_SECONDS="12"

USE_OPENAI="0"

SCAN_BATCH_SIZE="2"

MEDIA_IMAGE_MODEL="flux"
MEDIA_IMAGE_WIDTH="1024"
MEDIA_IMAGE_HEIGHT="1024"
# Optional comma-separated public image URLs for style/reference conditioning.
# First-time setup uploads can also populate this automatically via /api/app/style-pack.
MEDIA_STYLE_IMAGE_URLS=""
# Optional video endpoint for free-tier providers you control.
# Leave empty to use Pollinations media endpoint by default (https://gen.pollinations.ai/image/{prompt}).
# Set this only if you want a custom endpoint that returns binary video bytes from JSON { prompt }.
MEDIA_VIDEO_ENDPOINT=""
# Used only when MEDIA_VIDEO_ENDPOINT is set (custom provider mode).
MEDIA_VIDEO_METHOD="POST"
# Optional Pollinations video model override (when MEDIA_VIDEO_ENDPOINT is empty).
# Supported: veo, seedance, seedance-pro, wan, wan-fast, grok-video-pro, ltx-2, p-video, nova-reel
MEDIA_VIDEO_MODEL=""
# Pollinations default video model when MEDIA_VIDEO_MODEL is unset/invalid.
MEDIA_VIDEO_MODEL_DEFAULT="ltx-2"
# Optional deterministic seed for Pollinations video (integer).
MEDIA_VIDEO_SEED=""
# Optional Pollinations video controls.
MEDIA_VIDEO_DURATION=""
MEDIA_VIDEO_ASPECT_RATIO=""
MEDIA_VIDEO_AUDIO=""

MEDIA_VIDEO_TOKEN=""
